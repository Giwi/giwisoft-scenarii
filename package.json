{
  "name": "scenarii",
  "version": "1.0.0",
  "description": "Execute periodic YAML-defined scenarios to test web applications",
  "main": "dist/index.js",
  "bin": {
    "scenarii": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && npm run build:frontend",
    "build:backend": "tsc",
    "build:frontend": "cd frontend && npx ng build",
    "start": "node dist/index.js",
    "start:server": "node dist/index.js server",
    "dev": "npx concurrently -n server,frontend -c blue,green \"ts-node src/index.ts server\" \"cd frontend && npx ng serve --proxy-config proxy.conf.json\"",
    "dev:server": "ts-node src/index.ts server",
    "dev:frontend": "cd frontend && npx ng serve --proxy-config proxy.conf.json",
    "dev:once": "ts-node src/index.ts --once scenarios/lusk.yml",
    "dev:scenario": "npx chokidar 'scenarios/**/*.yml' -c 'npx ts-node src/index.ts --once {path}'",
    "lint": "tsc --noEmit",
    "test": "npm run build:backend && tsc -p tests/tsconfig.json && node --experimental-test-module-mocks --test 'dist-test/tests/**/*.test.js'",
    "screenshots": "ts-node take-screenshots.ts",
    "package": "npm run build && sh build-container.sh"
  },
  "dependencies": {
    "@lightpanda/browser": "^1.2.0",
    "better-sqlite3": "^12.10.0",
    "chalk": "^4.1.2",
    "commander": "^13.1.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "js-yaml": "^4.2.0",
    "node-cron": "^3.0.3",
    "pino": "^10.3.1",
    "playwright-core": "^1.60.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.0",
    "@types/node-cron": "^3.0.11",
    "@types/pino": "^7.0.4",
    "@types/ws": "^8.18.1",
    "chokidar-cli": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "optionalDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@emnapi/wasi-threads": "^1.2.1"
  }
}
